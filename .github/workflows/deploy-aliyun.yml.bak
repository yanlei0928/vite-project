# 部署到阿里云服务器示例
# 使用说明：
# 1. 在 GitHub 仓库 Settings -> Secrets and variables -> Actions 中添加以下 Secrets:
#    - SSH_PRIVATE_KEY: 你的服务器私钥（~/.ssh/id_rsa 内容）
#    - SERVER_HOST: 服务器 IP 或域名
#    - SERVER_USER: 服务器用户名（如 root）
#    - SERVER_PORT: SSH 端口（默认 22）
#    - DEPLOY_PATH: 服务器上的部署目录（如 /usr/share/nginx/html）

name: Deploy to Aliyun Server

on:
  push:
    branches:
      - dev

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. 拉取代码
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. 安装 Node.js
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20

      # 3. 安装 Yarn
      - name: Install Yarn
        run: npm install -g yarn

      # 4. 安装依赖
      - name: Install dependencies
        run: yarn install --frozen-lockfile

      # 5. 构建项目
      - name: Build project
        run: yarn build

      # 6. 部署到阿里云服务器（使用 SCP）
      - name: Deploy to Aliyun
        uses: appleboy/scp-action@v0.1.7
        with:
          host: ${{ secrets.SERVER_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          port: ${{ secrets.SERVER_PORT }}
          source: "dist/*"
          target: ${{ secrets.DEPLOY_PATH }}
          strip_components: 1  # 去掉 dist 目录层级，直接上传内容
          rm: true             # 先删除目标目录旧文件

      # 7. 可选：重启 Nginx（如果需要）
      - name: Restart Nginx
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_HOST }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          port: ${{ secrets.SERVER_PORT }}
          script: |
            # 测试 Nginx 配置是否正确
            nginx -t
            # 重载 Nginx（不中断服务）
            systemctl reload nginx
            echo "部署完成！"
